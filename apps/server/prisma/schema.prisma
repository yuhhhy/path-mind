generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Goal {
  id                String   @id @default(cuid())
  devUserId         String
  title             String
  description       String
  type              String
  status            String
  progress          Int      @default(0)
  estimatedMinutes  Int
  teachingStrategy  String
  outputFormats     String[]
  assessmentMethods String[]
  finalOutcome      String[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  steps LearningStep[]
}

model LearningStep {
  id               String   @id @default(cuid())
  goalId           String
  title            String
  description      String
  status           String
  estimatedMinutes Int
  order            Int
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  goal        Goal         @relation(fields: [goalId], references: [id], onDelete: Cascade)
  chatSession ChatSession?
  quizzes     Quiz[]
  transfer    Transfer?
  summary     StepSummary?
}

model ChatSession {
  id        String   @id @default(cuid())
  goalId    String
  stepId    String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  step     LearningStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
  messages ChatMessage[]
}

model ChatMessage {
  id        String   @id @default(cuid())
  sessionId String
  role      String
  content   String   @db.Text
  status    String   @default("complete")
  createdAt DateTime @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model Quiz {
  id           String   @id @default(cuid())
  goalId       String
  stepId       String
  status       String   @default("complete")
  draftContent String   @default("") @db.Text
  createdAt    DateTime @default(now())

  step      LearningStep   @relation(fields: [stepId], references: [id], onDelete: Cascade)
  questions QuizQuestion[]
  attempts  QuizAttempt[]
}

model QuizQuestion {
  id            String @id @default(cuid())
  quizId        String
  type          String
  question      String @db.Text
  options       String[]
  correctAnswer String @db.Text
  explanation   String @db.Text
  order         Int

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]
}

model QuizAttempt {
  id        String   @id @default(cuid())
  quizId    String
  score     Int
  createdAt DateTime @default(now())

  quiz    Quiz         @relation(fields: [quizId], references: [id], onDelete: Cascade)
  answers QuizAnswer[]
}

model QuizAnswer {
  id         String  @id @default(cuid())
  attemptId  String
  questionId String
  answer     String  @db.Text
  isCorrect  Boolean
  feedback   String  @db.Text

  attempt  QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  question QuizQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

model Transfer {
  id             String   @id @default(cuid())
  goalId         String
  stepId         String   @unique
  prompt         String   @db.Text
  promptStatus   String   @default("complete")
  userAnswer     String?  @db.Text
  aiFeedback     String?  @db.Text
  feedbackStatus String   @default("complete")
  score          Int?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  step LearningStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
}

model StepSummary {
  id              String   @id @default(cuid())
  goalId          String
  stepId          String   @unique
  content         String   @db.Text
  status          String   @default("complete")
  keyTakeaways    String[]
  weakPoints      String[]
  nextSuggestions String[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  step LearningStep @relation(fields: [stepId], references: [id], onDelete: Cascade)
}
